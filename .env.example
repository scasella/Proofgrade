# Required for grading requests and benchmark reproduction with the shipped runtime.
GEMINI_API_KEY=
# Optional alternative name supported by the underlying Gemini REST path.
GOOGLE_API_KEY=

# Optional proofgrade runtime overrides.
PROOFGRADE_MODEL=gemini-3-flash-preview
PROOFGRADE_PROMPT_VARIANT=guideline_gate_almost_boundary_v1
PROOFGRADE_LOG_LEVEL=INFO
PROOFGRADE_API_HOST=0.0.0.0
PROOFGRADE_API_PORT=8000

