FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/New_York

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    git \
    patch \
    wget \
    unzip \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /hyperagents

COPY . .

RUN pip install --no-cache-dir -r requirements_runtime_cpu.txt

CMD ["tail", "-f", "/dev/null"]
